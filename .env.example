# EncomVentas — Variables de entorno
# Copiar a .env y rellenar con valores reales

# Puerto del servidor (por defecto 3000)
PORT=3000

# API Key de Anthropic (Claude) para generación de propuestas con IA
ANTHROPIC_API_KEY=sk-ant-xxxxx

# En Coolify: configura estas variables en la sección "Environment Variables"
# del servicio, NO en un archivo .env local.
